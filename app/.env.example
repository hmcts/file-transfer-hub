# ═══════════════════════════════════════════════════════════════════
#  FTPS Server + SFTP Forwarder — Environment Configuration
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── FTPS Server (required) ─────────────────────────────────────────
PASV_ADDRESS=ftps.example.co.uk
FTP_USER_PASS=CHANGEME_use_a_strong_password

# ── Development mode (optional) ───────────────────────────────────
# Set to "true" to disable TLS entirely. Allows running without
# any certificates for local development and testing.
# ⚠  DO NOT enable in production — traffic will be unencrypted.
DEV_MODE=false

# ── Let's Encrypt (optional — remove to use a pre-mounted cert) ────
# Ignored when DEV_MODE=true.
LE_DOMAIN=ftps.example.co.uk
LE_EMAIL=admin@example.co.uk

# ── SFTP Forwarding (optional — remove SFTP_FWD_HOST to disable) ──
SFTP_FWD_HOST=sftp.remote-endpoint.example.com
SFTP_FWD_PORT=22
SFTP_FWD_USER=forwarder
SFTP_FWD_REMOTE_DIR=/incoming
SFTP_FWD_RETRIES=3
SFTP_FWD_RETRY_DELAY=10
SFTP_FWD_DELETE_AFTER=false